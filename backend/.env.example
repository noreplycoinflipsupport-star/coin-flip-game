PORT=5000
# MongoDB Atlas Connection String (required in production)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/coinflip?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d
ADMIN_SECRET=change_this_to_a_random_32_char_string
FRONTEND_URL=http://localhost:5000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Email Config (for OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Production (uncomment and fill):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/coinflip?retryWrites=true&w=majority
# FRONTEND_URL=https://yourdomain.com
# NODE_ENV=production
